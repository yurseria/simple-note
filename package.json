{
  "name": "simple-note",
  "version": "0.1.0",
  "private": true,
  "description": "A beautiful and simple plain text editor — Electron & Tauri",
  "author": "yurseria<yurseria@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/choose-target.mjs dev",
    "dev:electron": "npx turbo run dev --filter=@simple-note/electron",
    "dev:tauri": "npx turbo run dev --filter=@simple-note/tauri",
    "build": "node scripts/choose-target.mjs build",
    "build:electron": "npx turbo run build --filter=@simple-note/electron",
    "build:tauri": "npx turbo run build --filter=@simple-note/tauri",
    "package": "node scripts/choose-target.mjs package",
    "package:electron": "npm run build:electron && npm run --workspace=@simple-note/electron package",
    "package:tauri": "npm run --workspace=@simple-note/tauri package",
    "clean": "npm run --workspace=@simple-note/tauri clean"
  },
  "packageManager": "npm@11.5.1",
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
