{
  "productName": "Note",
  "version": "0.1.0",
  "identifier": "com.yurseria.simple-note",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Note",
        "width": 900,
        "height": 680,
        "minWidth": 300,
        "minHeight": 200,
        "decorations": true,
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "category": "public.app-category.productivity",
    "shortDescription": "A beautiful and simple plain text editor",
    "longDescription": "A clean and intuitive text editor designed for focused writing. Supports multi-tab, markdown preview, dark/light theme, and CJK input."
  },
  "plugins": {}
}
