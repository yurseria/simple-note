{
  "productName": "Note",
  "version": "0.6.5",
  "identifier": "com.yurseria.simple-note",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Note",
        "width": 900,
        "height": 680,
        "minWidth": 300,
        "minHeight": 200,
        "decorations": true,
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "category": "public.app-category.productivity",
    "fileAssociations": [
      {
        "ext": [
          "txt"
        ],
        "mimeType": "text/plain",
        "description": "Plain Text File"
      },
      {
        "ext": [
          "md",
          "markdown"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      },
      {
        "ext": [
          "log"
        ],
        "mimeType": "text/plain",
        "description": "Log File"
      }
    ],
    "shortDescription": "A beautiful and simple plain text editor",
    "longDescription": "A clean and intuitive text editor designed for focused writing. Supports multi-tab, markdown preview, dark/light theme, and CJK input."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yurseria/simple-note/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDMUIzNzIwNzdFNTlCOEEKUldTS20rVjNJRGNiL0tuYVcrTmdwNnFTejhFd0UvTUZDZTAwMWx1SjVXQnB6bi9IcjVIU25lUkcK"
    }
  }
}
