{
  "name": "@simple-note/electron",
  "version": "0.3.5",
  "description": "Simple Note — Electron shell",
  "main": "./out/main/index.js",
  "author": "yurseria<yurseria@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/yurseria/simple-note",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@simple-note/renderer": "*",
    "chardet": "^2.1.1",
    "electron-store": "^8.2.0",
    "iconv-lite": "^0.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  },
  "build": {
    "electronVersion": "41.0.0",
    "appId": "com.yurseria.simple-note",
    "productName": "Note",
    "mac": {
      "identity": null,
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "minimumSystemVersion": "13.0"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility;TextEditor"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "fileAssociations": [
      {
        "ext": "txt",
        "name": "Text File",
        "description": "Plain Text File",
        "role": "Editor"
      },
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "log",
        "name": "Log File",
        "description": "Log File",
        "role": "Editor"
      }
    ],
    "artifactName": "${productName}-Electron-${version}-${arch}.${ext}",
    "files": [
      "out/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
